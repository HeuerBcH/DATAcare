# ============================================
# DATAcare Environment Variables
# Copy this file to .env and update values
# ============================================

# ============================================
# DJANGO
# ============================================
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE
# ============================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=datacare_db
DB_USER=datacare_user
DB_PASSWORD=secure_password_here
DB_HOST=localhost
DB_PORT=5432

# ============================================
# DJANGO SUPERUSER (criado automaticamente no docker compose up)
# ============================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@datacare.local
DJANGO_SUPERUSER_PASSWORD=change-me

# ============================================
# CORS & API
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
VITE_API_URL=http://localhost:8000

# ============================================
# FRONTEND (Vite — variáveis de build do React)
# ============================================
# true = usa API mockada (sem backend); false = consome o backend real.
VITE_USE_MOCK=false

# ============================================
# MACHINE LEARNING
# ============================================
# Obs.: o backend usa o caminho fixo data_pipeline/models (settings.py); esta
# variável é apenas informativa/para scripts externos.
ML_MODELS_PATH=./data_pipeline/models

# ETL local (fora do Docker) — caminho para os CSVs brutos.
# Autodetectado em ../Dados (irmão de DATAcare/); ajuste se estiver em outro lugar.
# Rode com: PYTHONPATH=data_pipeline python -m src.etl.run_pipeline
DATACARE_RAW_DIR=../Dados

# Docker Compose — treino automático (serviço ml-trainer)
# FORCE_ML_TRAIN=true   # sempre retreina no docker compose up
# SKIP_ML_TRAIN=true    # nunca treina no up (sobe a stack mais rápido)
# ML_MAX_ROWS=120000    # cap de linhas no treino (evita OOM no Docker 8GB); 0 = todas
# ML_N_JOBS=2           # paralelismo da busca de hiperparâmetros. Cada worker
#                       # duplica os dados em memória — manter baixo evita OOM
#                       # (exit 137) no Docker de 8GB. Aumente se tiver mais RAM.

# ============================================
# EMAIL (optional)
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================
# AWS/Storage (optional)
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
